{
  "name": "muninsbok",
  "version": "0.1.0",
  "private": true,
  "description": "Open source bokföringswebbapp för småföretag och föreningar i Sverige",
  "license": "AGPL-3.0-or-later",
  "author": "Munins bok contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/muninsbok/muninsbok"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r --parallel exec vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "db:generate": "pnpm --filter @muninsbok/db generate",
    "db:migrate": "pnpm --filter @muninsbok/db migrate",
    "db:push": "pnpm --filter @muninsbok/db push",
    "db:seed": "pnpm --filter @muninsbok/db seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@8.15.0"
}
