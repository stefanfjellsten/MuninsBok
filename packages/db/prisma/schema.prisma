// Prisma schema for Munins bok
// Swedish bookkeeping application with multi-tenant support

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ORGANIZATION (tenant)
// ============================================

model Organization {
  id                   String   @id @default(cuid())
  orgNumber            String   @unique @map("org_number")
  name                 String
  fiscalYearStartMonth Int      @default(1) @map("fiscal_year_start_month")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  fiscalYears FiscalYear[]
  accounts    Account[]
  vouchers    Voucher[]
  documents   Document[]
  members     OrganizationMember[]
  voucherTemplates VoucherTemplate[]
  budgets     Budget[]
  approvalRules ApprovalRule[]
  customers   Customer[]
  invoices    Invoice[]

  @@map("organizations")
}

// ============================================
// USER
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  memberships    OrganizationMember[]
  refreshTokens  RefreshToken[]
  approvalSteps  ApprovalStep[]

  @@map("users")
}

// ============================================
// REFRESH TOKEN (for token revocation)
// ============================================

model RefreshToken {
  id        String   @id @default(cuid())
  jti       String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// ORGANIZATION MEMBER (user ↔ org with role)
// ============================================

model OrganizationMember {
  id             String         @id @default(cuid())
  userId         String         @map("user_id")
  organizationId String         @map("organization_id")
  role           MemberRole     @default(MEMBER)
  createdAt      DateTime       @default(now()) @map("created_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("organization_members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ============================================
// FISCAL YEAR
// ============================================

model FiscalYear {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  isClosed       Boolean  @default(false) @map("is_closed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vouchers     Voucher[]
  budgets      Budget[]

  @@unique([organizationId, startDate])
  @@index([organizationId])
  @@map("fiscal_years")
}

// ============================================
// ACCOUNT (chart of accounts per org)
// ============================================

model Account {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  number         String
  name           String
  type           AccountType
  isVatAccount   Boolean     @default(false) @map("is_vat_account")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  voucherLines VoucherLine[]

  @@unique([organizationId, number])
  @@map("accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// ============================================
// VOUCHER (verifikat)
// ============================================

model Voucher {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  fiscalYearId   String   @map("fiscal_year_id")
  number         Int
  date           DateTime
  description    String
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Correction: this voucher corrects another voucher
  correctsVoucherId   String?  @unique @map("corrects_voucher_id")
  correctsVoucher     Voucher? @relation("VoucherCorrection", fields: [correctsVoucherId], references: [id])
  correctedByVoucher  Voucher? @relation("VoucherCorrection")

  // Approval workflow
  status              VoucherStatus @default(DRAFT)
  submittedAt         DateTime?     @map("submitted_at")
  submittedByUserId   String?       @map("submitted_by_user_id")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fiscalYear   FiscalYear    @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  lines        VoucherLine[]
  documents    Document[]
  approvalSteps ApprovalStep[]
  invoice      Invoice?

  @@unique([fiscalYearId, number])
  @@index([organizationId])
  @@index([date])
  @@index([organizationId, status])
  @@map("vouchers")
}

// ============================================
// VOUCHER LINE (verifikatrad)
// ============================================

model VoucherLine {
  id            String  @id @default(cuid())
  voucherId     String  @map("voucher_id")
  accountId     String  @map("account_id")
  accountNumber String  @map("account_number")
  debit         Int     @default(0)
  credit        Int     @default(0)
  description   String?

  // Relations
  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([accountId])
  @@index([accountNumber])
  @@map("voucher_lines")
}

// ============================================
// DOCUMENT (attached files)
// ============================================

model Document {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  voucherId      String?  @map("voucher_id")
  filename       String
  mimeType       String   @map("mime_type")
  storageKey     String   @map("storage_key")
  size           Int
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  voucher      Voucher?     @relation(fields: [voucherId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([voucherId])
  @@map("documents")
}

// ============================================
// VOUCHER TEMPLATE (verifikatmall)
// ============================================

model VoucherTemplate {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Recurring schedule (null = not recurring)
  isRecurring       Boolean           @default(false) @map("is_recurring")
  frequency         RecurringFrequency?
  dayOfMonth        Int?              @map("day_of_month")
  nextRunDate       DateTime?         @map("next_run_date")
  lastRunDate       DateTime?         @map("last_run_date")
  recurringEndDate  DateTime?         @map("recurring_end_date")

  // Relations
  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines        VoucherTemplateLine[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isRecurring, nextRunDate])
  @@map("voucher_templates")
}

enum RecurringFrequency {
  MONTHLY
  QUARTERLY
}

// ============================================
// VOUCHER TEMPLATE LINE (verifikatmallrad)
// ============================================

model VoucherTemplateLine {
  id            String  @id @default(cuid())
  templateId    String  @map("template_id")
  accountNumber String  @map("account_number")
  debit         Int     @default(0)
  credit        Int     @default(0)
  description   String?

  // Relations
  template VoucherTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("voucher_template_lines")
}

// ============================================
// BUDGET
// ============================================

model Budget {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  fiscalYearId   String   @map("fiscal_year_id")
  name           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fiscalYear   FiscalYear   @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  entries      BudgetEntry[]

  @@unique([organizationId, fiscalYearId, name])
  @@index([organizationId])
  @@index([fiscalYearId])
  @@map("budgets")
}

// ============================================
// BUDGET ENTRY (budgetrad per konto + månad)
// ============================================

model BudgetEntry {
  id            String @id @default(cuid())
  budgetId      String @map("budget_id")
  accountNumber String @map("account_number")
  month         Int
  amount        Int

  // Relations
  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, accountNumber, month])
  @@index([budgetId])
  @@map("budget_entries")
}

// ============================================
// VOUCHER STATUS
// ============================================

enum VoucherStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// APPROVAL RULE
// ============================================

model ApprovalRule {
  id             String     @id @default(cuid())
  organizationId String     @map("organization_id")
  name           String
  minAmount      Int        @map("min_amount")
  maxAmount      Int?       @map("max_amount")
  requiredRole   MemberRole @map("required_role")
  stepOrder      Int        @map("step_order")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("approval_rules")
}

// ============================================
// APPROVAL STEP
// ============================================

model ApprovalStep {
  id              String             @id @default(cuid())
  voucherId       String             @map("voucher_id")
  stepOrder       Int                @map("step_order")
  requiredRole    MemberRole         @map("required_role")
  approverUserId  String?            @map("approver_user_id")
  status          ApprovalStepStatus @default(PENDING)
  comment         String?
  decidedAt       DateTime?          @map("decided_at")
  createdAt       DateTime           @default(now()) @map("created_at")

  // Relations
  voucher  Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  approver User?   @relation(fields: [approverUserId], references: [id])

  @@index([voucherId])
  @@index([approverUserId])
  @@index([status])
  @@map("approval_steps")
}

// ============================================
// CUSTOMER (kund)
// ============================================

model Customer {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  customerNumber Int      @map("customer_number")
  name           String
  email          String?
  phone          String?
  address        String?
  postalCode     String?  @map("postal_code")
  city           String?
  country        String?  @default("SE")
  orgNumber      String?  @map("org_number")
  vatNumber      String?  @map("vat_number")
  reference      String?
  paymentTermDays Int     @default(30) @map("payment_term_days")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@unique([organizationId, customerNumber])
  @@index([organizationId])
  @@map("customers")
}

// ============================================
// INVOICE (faktura)
// ============================================

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  CREDITED
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  customerId     String        @map("customer_id")
  invoiceNumber  Int           @map("invoice_number")
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @map("issue_date")
  dueDate        DateTime      @map("due_date")
  paidDate       DateTime?     @map("paid_date")
  ourReference   String?       @map("our_reference")
  yourReference  String?       @map("your_reference")
  notes          String?
  /// Amount before VAT in öre
  subtotal       Int           @default(0)
  /// VAT amount in öre
  vatAmount      Int           @default(0) @map("vat_amount")
  /// Total amount incl. VAT in öre
  totalAmount    Int           @default(0) @map("total_amount")
  /// Link to generated voucher when paid
  voucherId      String?       @unique @map("voucher_id")
  /// For credit invoices: the original invoice being credited
  creditedInvoiceId String?    @map("credited_invoice_id")
  sentAt         DateTime?     @map("sent_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer        Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  voucher         Voucher?     @relation(fields: [voucherId], references: [id])
  creditedInvoice Invoice?     @relation("InvoiceCredit", fields: [creditedInvoiceId], references: [id])
  creditInvoices  Invoice[]    @relation("InvoiceCredit")
  lines           InvoiceLine[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([organizationId, status])
  @@map("invoices")
}

// ============================================
// INVOICE LINE (fakturarad)
// ============================================

model InvoiceLine {
  id            String  @id @default(cuid())
  invoiceId     String  @map("invoice_id")
  description   String
  quantity       Int     @default(100)
  /// Unit price in öre
  unitPrice     Int     @map("unit_price")
  /// VAT rate as percentage × 100 (e.g. 2500 = 25%)
  vatRate       Int     @default(2500) @map("vat_rate")
  /// Line amount excl. VAT in öre (quantity/100 × unitPrice)
  amount        Int     @default(0)
  accountNumber String? @map("account_number")

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_lines")
}
