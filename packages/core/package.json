{
  "name": "@muninsbok/core",
  "version": "0.1.0",
  "private": true,
  "description": "Ren bokföringslogik utan externa beroenden",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api-types": {
      "types": "./dist/api-types/index.d.ts",
      "import": "./dist/api-types/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./reports": {
      "types": "./dist/reports/index.d.ts",
      "import": "./dist/reports/index.js"
    },
    "./sie": {
      "types": "./dist/sie/index.d.ts",
      "import": "./dist/sie/index.js"
    },
    "./chart-of-accounts": {
      "types": "./dist/chart-of-accounts/index.d.ts",
      "import": "./dist/chart-of-accounts/index.js"
    },
    "./voucher": {
      "types": "./dist/voucher/index.d.ts",
      "import": "./dist/voucher/index.js"
    },
    "./csv-import": {
      "types": "./dist/csv-import.d.ts",
      "import": "./dist/csv-import.js"
    },
    "./i18n": {
      "types": "./dist/i18n.d.ts",
      "import": "./dist/i18n.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  }
}
