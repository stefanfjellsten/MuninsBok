# Environment (development | production | test)
NODE_ENV=development

# Database
DATABASE_URL=postgresql://muninsbok:muninsbok@localhost:5432/muninsbok
# DATABASE_POOL_SIZE=20  # Max database connections (default: 20)

# Docker Compose — used by `docker compose up postgres -d`
POSTGRES_USER=muninsbok
POSTGRES_PASSWORD=muninsbok
POSTGRES_DB=muninsbok

# API Server
HOST=0.0.0.0
PORT=3000

# CORS — allowed origin (defaults to http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# JWT secret — enables user authentication (register/login/JWT tokens)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret

# API Key — simple shared-secret auth, ignored when JWT_SECRET is set (optional)
# API_KEY=your-secret-key-here

# Frontend (for development)
VITE_API_URL=http://localhost:3000
# Frontend org-scoped banking feature gate:
# - empty/unset = enabled for all organizations
# - * = explicit enable for all organizations
# - comma-separated IDs = pilot only for listed organizations
# Keep in sync with BANK_ENABLED_ORG_IDS.
VITE_BANK_ENABLED_ORG_IDS=

# Backend org-scoped banking feature gate for /bank endpoints.
# Same syntax as VITE_BANK_ENABLED_ORG_IDS.
BANK_ENABLED_ORG_IDS=

# OCR PDF support (requires pdftoppm / Poppler in runtime image)
# OCR_ENABLE_PDF=false

# Database migration mode for container startup:
# deploy | fallback | push | skip
# DB_MIGRATION_MODE=fallback

# Prometheus metrics — exposed at GET /metrics
# METRICS_ENABLED=true
